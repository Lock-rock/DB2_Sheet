First we create a dirctory:
mkdir license

Now we check directory:
pwd
result show:/db2/license

now change directory : aese_c
cd aese_c

now list dirctory:
ls -ltt
result:
		db2
		qs_server
		readme
		warehouse

now change and go in warehouse:
cd warehouse

now list dirctory:
ls -ltr

result:
		warehouse_prereq_server.xml
		warehouse_prereq_client.xml
		db2aese_c.lic
