Find user and grants:

db2 "select * from SYSCAT.DBAUTH  where GRANTEE = 'AIUSER' "

All authorities, privileges and permissions are listed below.


System Catalog              Description
SYSCAT.DBAUTH	              Lists the database privileges
select DBADMAUTH,DATAACCESSAUTH,CREATETABAUTH,EXPLAINAUTH,CONNECTAUTH,ACCESSCTRLAUTH from syscat.dbauth where GRANTEE ='VSINGH'

SYSCAT.TABAUTH              Lists the table and view privileges
select TABSCHEMA,TABNAME,CONTROLAUTH,ALTERAUTH,DELETEAUTH,INDEXAUTH,INSERTAUTH,SELECTAUTH,UPDATEAUTH from SYSCAT.TABAUTH where GRANTEE ='VSINGH'

SYSCAT.COLAUTH              Lists the column privileges
select COLNO,TABSCHEMA,TABNAME,COLNAME,PRIVTYPE from SYSCAT.COLAUTH where GRANTEE ='VSINGH'

SYSCAT.PACKAGEAUTH          Lists the package privileges
select PKGSCHEMA,PKGNAME,CONTROLAUTH,EXECUTEAUTH from SYSCAT.PACKAGEAUTH where GRANTEE ='VSINGH'

SYSCAT.INDEXAUTH            Lists the index privileges
select INDNAME,CONTROLAUTH,INDSCHEMA from SYSCAT.INDEXAUTH where GRANTEE ='VSINGH'

SYSCAT.SCHEMAAUTH           Lists the schema privileges
select SCHEMANAME,ALTERINAUTH,CREATEINAUTH,DROPINAUTH from SYSCAT.SCHEMAAUTH where GRANTEE ='VSINGH'

SYSCAT.PASSTHRUAUTH         Lists the server privileges
select SERVERNAME from SYSCAT.PASSTHRUAUTH where GRANTEE ='VSINGH'

SYSCAT.ROUTINEAUTH       	Lists the routine (functions,methods, and stored procedures) privileges
select SCHEMA,SPECIFICNAME,TYPESCHEMA,TYPENAME,ROUTINETYPE,EXECUTEAUTH,GRANT_TIME from SYSCAT.ROUTINEAUTH where GRANTEE ='VSINGH'

Check table-level privileges:
SELECT GRANTEE, TABNAME, TABSCHEMA, CONTROLAUTH, SELECTAUTH, INSERTAUTH,UPDATEAUTH, DELETEAUTH, ALTERAUTH, INDEXAUTH FROM SYSCAT.TABAUTH WHERE GRANTEE = 'VSINGH';

Check schema privileges:
SELECT GRANTEE, SCHEMANAME, CREATEINAUTH, ALTERINAUTH, DROPINAUTH FROM SYSCAT.SCHEMAAUTH WHERE GRANTEE = 'VSINGH';

Check role-based privileges (very important):
SELECT GRANTEE, ROLENAME FROM SYSCAT.ROLEAUTH WHERE GRANTEE = 'VSINGH';
