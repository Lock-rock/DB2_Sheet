Table column details:

SELECT 
    COLNAME AS COLUMN_NAME, 
    TYPENAME AS DATA_TYPE, 
    LENGTH AS DATA_LENGTH,  -- For VARCHAR, etc.
    NULLS AS NULLABLE
FROM SYSCAT.COLUMNS
WHERE TABSCHEMA = 'MISRPA' 
  AND TABNAME = 'CLAIM_HEALTH_IIB'
  AND TYPENAME IN ('VARCHAR', 'CHAR', 'VARGRAPHIC', 'CLOB', 'DBCLOB')  -- Filter to text types
ORDER BY COLNO;  -- Column order
